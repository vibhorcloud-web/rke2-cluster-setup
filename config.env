# instant-rke2-lab — RKE2 + Cilium on Multipass
# Source-able shell config. Edit knobs here; scripts read this file.

# Ubuntu release for Multipass
UBUNTU_RELEASE="24.04"

# VMs: "name cpus memory_G disk_G role"
# role is one of: server, agent
# Note: IP addresses are managed dynamically by Multipass DHCP.
VM_LIST=(
  "cp1     4  8G  60G server"
  "worker1 6 16G  80G agent"
  "worker2 6 16G  80G agent"
)

# RKE2
RKE2_CHANNEL="stable"
RKE2_VERSION=""               # leave empty to use channel; e.g. "v1.35.4+rke2r1"
CLUSTER_CIDR="10.42.0.0/16"
SERVICE_CIDR="10.43.0.0/16"

# Cilium
CILIUM_HUBBLE_UI="true"

# Paths — auto-detect repo root from this file's location.
: "${LAB_ROOT:=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
VM_DIR="${LAB_ROOT}/vms"
STATE_DIR="${LAB_ROOT}/.state"
SSH_KEY="${STATE_DIR}/ssh_key"

# VM login user
SSH_USER="ubuntu"
